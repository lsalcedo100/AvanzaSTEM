# Required for the newsletter email API provider.
RESEND_API_KEY=

# Optional sender identity for newsletter notifications.
# If omitted, the app uses: Avanza STEM <newsletter@avanzastem.org>
# This sender only works after you verify the Avanza STEM domain in Resend.
NEWSLETTER_FROM_EMAIL=

# Optional override for the destination inbox.
# If omitted, signups are sent to liam@avanzastem.org.
NEWSLETTER_RECIPIENT_EMAIL=
